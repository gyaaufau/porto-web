---
export interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  id: string;
}

const { eyebrow, title, description, id } = Astro.props;
---
<section class="section-shell" id={id}>
  <div class="section-heading">
    <p class="section-eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
    {description && <p class="section-description">{description}</p>}
  </div>
  <div class="section-content">
    <slot />
  </div>
</section>
