---
import logo from "../data/brand/logo.svg";

const navItems = [
  { label: "Home", href: "#top" },
  { label: "Projects", href: "#projects" },
  { label: "Experience", href: "#work-experience" },
  { label: "About", href: "#about" },
  { label: "Certificates", href: "#certificates" },
  { label: "Contact", href: "#contact" }
];
---
<nav class="navbar panel" aria-label="Primary">
  <div class="navbar-top">
    <a class="navbar-brand" href="#top">
      <img class="navbar-brand-logo" src={logo.src} alt="gialoop logo" />
    </a>

    <button
      class="navbar-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-drawer"
      aria-label="Open navigation menu"
      data-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="navbar-links" id="primary-drawer" data-nav-drawer>
    {
      navItems.map((item) => (
        <a href={item.href} data-nav-link={item.href}>
          {item.label}
        </a>
      ))
    }
    <button class="theme-toggle" type="button" aria-label="Switch to light mode" data-theme-toggle>
      <span class="theme-toggle-icon" aria-hidden="true">◐</span>
      <span class="theme-toggle-label">Dark</span>
    </button>
  </div>
</nav>

<script>
  const nav = document.querySelector(".navbar");
  const navToggle = nav?.querySelector("[data-nav-toggle]");
  const navDrawer = nav?.querySelector("[data-nav-drawer]");
  const navLinks = document.querySelectorAll("[data-nav-link]");
  const themeToggle = nav?.querySelector("[data-theme-toggle]");
  const themeToggleLabel = themeToggle?.querySelector(".theme-toggle-label");
  const mobileBreakpoint = window.matchMedia("(max-width: 720px)");
  const themeStorageKey = "gialoop-theme";

  const setDrawerState = (open) => {
    if (!nav || !navToggle || !navDrawer) return;

    nav.dataset.drawerOpen = open ? "true" : "false";
    navToggle.setAttribute("aria-expanded", open ? "true" : "false");
    navToggle.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
    navDrawer.toggleAttribute("data-open", open);
  };

  const setActiveLink = () => {
    const currentHash = window.location.hash || "#top";

    navLinks.forEach((link) => {
      const active = link.getAttribute("href") === currentHash;
      link.toggleAttribute("data-active", active);
      link.setAttribute("aria-current", active ? "page" : "false");
    });
  };

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem(themeStorageKey, theme);

    if (!themeToggle || !themeToggleLabel) return;

    const nextTheme = theme === "dark" ? "light" : "dark";
    themeToggleLabel.textContent = theme === "dark" ? "Dark" : "Light";
    themeToggle.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
  };

  navToggle?.addEventListener("click", () => {
    const isOpen = navToggle.getAttribute("aria-expanded") === "true";
    setDrawerState(!isOpen);
  });

  themeToggle?.addEventListener("click", () => {
    const currentTheme = document.documentElement.dataset.theme === "light" ? "light" : "dark";
    applyTheme(currentTheme === "dark" ? "light" : "dark");
  });

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (mobileBreakpoint.matches) setDrawerState(false);
    });
  });

  mobileBreakpoint.addEventListener("change", (event) => {
    if (!event.matches) setDrawerState(false);
  });

  applyTheme(document.documentElement.dataset.theme === "light" ? "light" : "dark");
  setActiveLink();
  setDrawerState(false);
  window.addEventListener("hashchange", setActiveLink);
</script>
