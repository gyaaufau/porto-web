---
export interface Props {
  paragraphs: string[];
  openToOpportunities?: boolean;
  skills?: string[];
  tech?: string[];
  softSkills?: string[];
}

const { paragraphs, openToOpportunities = true, skills = [], tech = [], softSkills = [] } = Astro.props;
---
<div class="about-grid">
  {
    paragraphs.map((paragraph) => (
      <p class="about-copy">{paragraph}</p>
    ))
  }
  <div class="about-status-card panel">
    <div class="about-status-copy">
      <p class="terminal-line">[ open to opportunities ]</p>
      <p class="about-status-text">
        {openToOpportunities ? "Available for freelance, full-time, and collaboration." : "Currently heads down, not taking new opportunities."}
      </p>
    </div>
    <div
      class:list={[
        "about-status-toggle",
        openToOpportunities && "is-active"
      ]}
      role="switch"
      aria-checked={openToOpportunities ? "true" : "false"}
      aria-label="Open to opportunities"
    >
      <span class="about-status-track" aria-hidden="true">
        <span class="about-status-thumb"></span>
      </span>
      <span class="about-status-label">{openToOpportunities ? "On" : "Off"}</span>
    </div>
  </div>
  <div class="about-list-section about-list-section-single panel">
    <div class="about-note">
      <p class="terminal-line">[ skills ]</p>
      <ul class="about-list">
        {skills.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
  <div class="about-list-section about-list-section-single panel">
    <div class="about-note">
      <p class="terminal-line">[ tech ]</p>
      <ul class="about-list">
        {tech.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
  <div class="about-list-section about-list-section-single panel">
    <div class="about-note">
      <p class="terminal-line">[ soft skill ]</p>
      <ul class="about-list">
        {softSkills.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</div>
