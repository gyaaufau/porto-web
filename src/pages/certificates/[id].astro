---
import CertificateDetailView from "../../components/CertificateDetailView.astro";
import Navbar from "../../components/Navbar.astro";
import { portfolioCertificates } from "../../data/portfolio";
import { absoluteUrl } from "../../data/seo";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return portfolioCertificates.map((certificate) => ({
    params: { id: certificate.id },
    props: { certificate }
  }));
}

const { certificate } = Astro.props;
const certificateSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOccupationalCredential",
  name: certificate.title,
  description: certificate.summary,
  url: absoluteUrl(`/certificates/${certificate.id}`),
  credentialCategory: certificate.type,
  recognizedBy: {
    "@type": "Organization",
    name: certificate.issuer
  }
};
---
<BaseLayout
  title={`${certificate.title} | Gialoop`}
  description={certificate.summary}
  structuredData={certificateSchema}
>
  <main class="page-shell">
    <Navbar />

    <section class="project-page-top panel">
      <a class="back-link" href="/#certificates">back / certificates</a>
    </section>

    <CertificateDetailView certificate={certificate} />
  </main>
</BaseLayout>
