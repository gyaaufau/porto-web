---
import "../styles/global.css";
import logo from "../data/brand/logo-loop.svg";
import myPhoto from "../data/myself/me.jpg";
import { siteConfig } from "../data/seo";

export interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  pageType?: "website" | "article" | "profile";
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogImage = myPhoto.src,
  ogImageAlt = "Portrait of Argya Aulia Fauzandika",
  pageType = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
  structuredData
} = Astro.props;
const canonicalUrl = Astro.url;
const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const ogImageUrl = new URL(ogImage, Astro.site ?? siteConfig.siteUrl).toString();
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={siteConfig.personName} />
    <meta name="theme-color" content="#f4efe4" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={pageType === "article" ? "article" : "website"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/svg+xml" href={logo.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script is:inline>
      (() => {
        const storageKey = "gialoop-theme";
        const savedTheme = localStorage.getItem(storageKey);
        const theme = savedTheme === "light" || savedTheme === "dark" ? savedTheme : "light";
        const themeColorMeta = document.querySelector('meta[name="theme-color"]');

        document.documentElement.dataset.theme = theme;

        if (themeColorMeta) {
          themeColorMeta.setAttribute("content", theme === "light" ? "#f4efe4" : "#09121f");
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
